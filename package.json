{
  "name": "@zhuk/spego",
  "version": "0.6.0",
  "description": "Agent-first product orchestration: markdown-first artifact engine with SQLite indexing.",
  "type": "module",
  "bin": {
    "spego": "dist/cli.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "README.md",
    "CHANGELOG.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "spego": "tsx src/cli.ts",
    "pretest": "npm run build",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint src test"
  },
  "dependencies": {
    "commander": "^12.1.0",
    "slugify": "^1.6.6",
    "yaml": "^2.5.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^22.7.4",
    "eslint": "^10.3.0",
    "tsx": "^4.19.1",
    "typescript": "^5.6.2",
    "typescript-eslint": "^8.59.2",
    "vitest": "^2.1.1"
  },
  "engines": {
    "node": ">=22.14.0"
  },
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/victorzhuk/spego.git"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org"
  }
}
