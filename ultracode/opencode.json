{
  "$schema": "https://opencode.ai/config.json",

  "model": "openai/gpt-5.5",

  // ── Global bash safety rails ──────────────────────────────────────────────
  // The orchestrator (ultracode.py) itself controls git; agents must not.
  "permission": {
    "bash": {
      "git *": "deny",
      "rm -rf *": "deny",
      "curl *": "deny",
      "wget *": "deny",
      "pip install *": "deny",
      "npm install *": "deny",
      "ssh *": "deny"
    }
  },

  "agent": {

    // ── Manager: decomposes requirements → TaskBreakdown JSON ──────────────
    "ultramanager": {
      "description": "Decomposes a high-level coding requirement into parallelisable sub-tasks and emits a TaskBreakdown JSON. Invoke for planning only — never for implementation.",
      "mode": "primary",
      "model": "openai/gpt-5.5",
      "temperature": 0.1,
      "max_steps": 8,
      "prompt": ".opencode/agents/ultramanager.md",
      "permission": {
        "read": "allow",
        "edit": "deny",
        "bash": {
          "*": "deny",
          "rg *": "allow",
          "ls *": "allow",
          "cat *": "allow",
          "find . -name *": "allow"
        },
        "task": {
          "*": "deny"
        },
        "webfetch": "allow",
        "websearch": "allow",
        "glob": "allow",
        "grep": "allow"
      },
      "color": "primary"
    },

    // ── Worker: implements a single sub-task ───────────────────────────────
    "ultraworker": {
      "description": "Implements one precisely scoped sub-task from a TaskBreakdown. Touches only the files listed in its task spec. Runs tests after implementation. Reports ULTRAWORKER_STATUS: SUCCESS or FAILURE.",
      "mode": "subagent",
      "model": "zhipuai/glm-5.1",
      "temperature": 0.15,
      "max_steps": 30,
      "prompt": ".opencode/agents/ultraworker.md",
      "permission": {
        "read": "allow",
        "edit": "allow",
        "bash": {
          "*": "deny",
          // test runners
          "pytest *": "allow",
          "python -m pytest *": "allow",
          "go test *": "allow",
          "cargo test *": "allow",
          "npm test *": "allow",
          "npx vitest *": "allow",
          // linters / formatters
          "ruff *": "allow",
          "black *": "allow",
          "mypy *": "allow",
          "gofmt *": "allow",
          "golangci-lint *": "allow",
          // read-only inspection
          "ls *": "allow",
          "rg *": "allow",
          "cat *": "allow",
          "diff *": "allow",
          "find . -name *": "allow"
        },
        "task": "deny",
        "glob": "allow",
        "grep": "allow",
        "webfetch": "deny",
        "websearch": "deny",
        "todowrite": "allow"
      },
      "color": "secondary"
    },

    // ── Verifier: aggregates diffs and runs the full test suite ────────────
    "ultraverifier": {
      "description": "Final QA agent. Aggregates all sub-task diffs, runs the full test suite, and emits a structured JSON verdict. Invoke only after all workers complete.",
      "mode": "primary",
      "model": "openai/gpt-5.5",
      "temperature": 0.0,
      "max_steps": 20,
      "prompt": ".opencode/agents/ultraverifier.md",
      "permission": {
        "read": "allow",
        "edit": "deny",
        "bash": {
          "*": "deny",
          // full test suite only
          "pytest": "allow",
          "pytest *": "allow",
          "python -m pytest *": "allow",
          "go test ./...": "allow",
          "go test *": "allow",
          "cargo test *": "allow",
          "npm test": "allow",
          "npm test *": "allow",
          // read-only
          "ls *": "allow",
          "rg *": "allow",
          "cat *": "allow",
          "diff *": "allow",
          "git diff": "allow",
          "git status": "allow",
          "git log --oneline *": "allow"
        },
        "task": "deny",
        "glob": "allow",
        "grep": "allow",
        "webfetch": "deny",
        "websearch": "deny"
      },
      "color": "success"
    }
  }
}
